{
  "name": "metalsmith-menu-plus",
  "version": "0.6.0",
  "description": "Automatic hierarchical navigation generator for Metalsmith sites",
  "type": "module",
  "exports": "./src/index.js",
  "engines": {
    "node": ">= 18.0.0"
  },
  "scripts": {
    "changelog": "auto-changelog -u --commit-limit false --ignore-commit-pattern '^((dev|chore|ci):|Release)'",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "coverage": "c8 --include=src/**/*.js --reporter=lcov --reporter=text-summary node --test test/index.js",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "release:check": "npm run check:ci && release-it --dry-run",
    "test": "c8 --include=src/**/*.js node --test test/index.js",
    "test:coverage": "c8 npm test",
    "test:debug": "DEBUG=metalsmith-menu-plus:* npm test",
    "depcheck": "depcheck",
    "audit": "npm audit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wernerglinka/metalsmith-menu-plus.git"
  },
  "keywords": [
    "metalsmith",
    "metalsmith-plugin"
  ],
  "files": [
    "src",
    "README.md"
  ],
  "author": "Werner Glinka <werner@glinka.co>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wernerglinka/metalsmith-menu-plus/issues"
  },
  "homepage": "https://github.com/wernerglinka/metalsmith-menu-plus",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "auto-changelog": "^2.5.0",
    "c8": "^10.1.3",
    "metalsmith": "^2.7.0",
    "release-it": "^19.2.4"
  },
  "peerDependencies": {
    "metalsmith": "^2.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
